{
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "description": "WelcomeBot for Discord",
  "homepage": "https://github.com/chump29/welcome",
  "keywords": [
    "welcome",
    "message"
  ],
  "license": "GPL-3.0-only",
  "name": "welcome",
  "module": "index.ts",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/welcome.git"
  },
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "clean": "rimraf node_modules bun.lock",
    "dev": "bun --watch run index.ts",
    "lint": "bun run lint:biome && bun run lint:env",
    "lint:biome": "biome check --write --verbose",
    "lint:ci": "biome ci --verbose --reporter=default --reporter=github",
    "lint:env": "dotenv-linter check .",
    "preinstall": "bunx only-allow bun",
    "postinstall": "config-init",
    "prepare": "husky",
    "prod": "bun run index.ts"
  },
  "lint-staged": {
    "*.{json,ts}": "biome ci --no-errors-on-unmatched",
    ".env*": "dotenv-linter check"
  },
  "dependencies": {
    "date-and-time": "^4.4.0",
    "discord.js": "^14.26.2",
    "discord.js-rate-limiter": "^1.3.2",
    "recolors": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@bun-security-scanner/osv": "^1.0.0",
    "@postfmly/config": "^1.0.0",
    "@types/bun": "^1.3.12",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.6.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "engineStrict": true,
  "engines": {
    "bun": "~1.3",
    "node": "^24"
  }
}
